# Ignore Quarto rendered output directories
_site/
docs/

# Ignore any cache files created during the build process
.Rhistory
.Rproj.user/
.Rdata
renv/library/
renv/cache/
__pycache__/
node_modules/

# Ignore logs and temporary files
*.log
*.tmp

# Ignore system-specific files
.DS_Store
Thumbs.db

# Ignore lock files
*.lock

# Ignore Quarto generated HTML, CSS, and other rendered outputs
*.html
*.css
*.pdf
*.docx
*.pptx

# Quarto cache files
.quarto/

# Ignore the _freeze directory if using Quarto for static rendering
_freeze/

# Ignore renv lockfile if you don't want to track it
renv.lock
